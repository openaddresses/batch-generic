{
    "name": "@openaddresses/batch-generic",
    "type": "module",
    "version": "25.0.0",
    "description": "JSON Schema/ORM Hybrid Helper for Drizzle-ORM",
    "main": "./dist/generic.js",
    "types": "./generic.ts",
    "scripts": {
        "lint": "eslint generic.ts lib/ test/",
        "test": "tsx --test --test-concurrency=1 test/generic.test.ts test/pool.test.ts test/unit.test.ts",
        "coverage": "c8 --reporter=text --reporter=lcov npm test",
        "doc": "typedoc generic.ts",
        "build": "tsc --build"
    },
    "c8": {
        "all": true,
        "include": [
            "generic.ts",
            "lib/**/*.ts"
        ],
        "extension": [
            ".ts"
        ],
        "exclude": [
            "test/**",
            "dist/**"
        ]
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/openaddresses/batch-generic.git"
    },
    "author": "Nick Ingalls <nick@ingalls.ca>",
    "license": "ISC",
    "bugs": {
        "url": "https://github.com/openaddresses/batch-generic/issues"
    },
    "homepage": "https://github.com/openaddresses/batch-generic#readme",
    "peerDependencies": {
        "drizzle-kit": "^0.31.0",
        "drizzle-orm": "^0.45.0"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/express": "^5.0.0",
        "@types/geojson": "^7946.0.13",
        "c8": "^11.0.0",
        "eslint": "^10.0.0",
        "tsx": "^4.21.0",
        "typedoc": "^0.28.1",
        "typescript": "^6.0.0",
        "typescript-eslint": "^8.0.0"
    },
    "dependencies": {
        "@openaddresses/batch-error": "^2.1.2",
        "@turf/bbox": "^7.0.0",
        "postgres": "^3.4.3",
        "wkx": "^0.5.0"
    }
}
